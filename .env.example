# Resend API key — https://resend.com/api-keys
RESEND_KEY=

# Google reCAPTCHA v3 (invisible, score-based) — https://www.google.com/recaptcha/admin
# Create a v3 site, add domains: localhost and your production host (e.g. yang-jiao.vercel.app).
# Site key is public (browser); secret key stays server-side only.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Verified sender domain in Resend (e.g. onboarding@yourdomain.com)
SENDER_EMAIL=
# Inbox that receives a BCC copy of contact-form replies
FORWARD_EMAIL=
