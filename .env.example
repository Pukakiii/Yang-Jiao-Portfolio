# Formspree form ID — https://formspree.io (create form, copy ID from URL f/abcxyz → abcxyz)
FORMSPREE_FORM_ID=

# Google reCAPTCHA v3 (invisible, score-based) — https://www.google.com/recaptcha/admin
# Create a v3 site, add domains: localhost and your production host (e.g. jiaoyang.vercel.app).
# Site key is public (browser); secret key stays server-side only.
# Also used to sign the contact form rate-limit cookie (2 messages per 24h).
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
